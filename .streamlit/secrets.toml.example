# Copy this file to .streamlit/secrets.toml and fill in your keys.
# secrets.toml is git-ignored — never commit real credentials.

# Anthropic (required for live mode; leave blank for mock mode)
ANTHROPIC_API_KEY = ""

# Trello (all four required to enable card export)
TRELLO_API_KEY  = ""
TRELLO_TOKEN    = ""
TRELLO_BOARD_ID = ""   # The ID from your board's URL: trello.com/b/<BOARD_ID>/...
TRELLO_LIST_ID  = ""   # ID of the "Backlog" list — get it from the Trello API or browser
